# Origin(s) allowed to embed this app in an <iframe> (CSP frame-ancestors).
# Set this in your Vercel project: Settings -> Environment Variables.
#
# Single origin:
#   ALLOWED_FRAME_ANCESTOR=https://official.example
#
# Multiple origins (space-separated, e.g. prod + staging):
#   ALLOWED_FRAME_ANCESTOR=https://official.example https://staging.official.example
#
# Leave unset to deny ALL framing (deny-by-default). The app still loads directly.
ALLOWED_FRAME_ANCESTOR=

# Vercel Blob read/write token, used by /api/upload to issue browser upload tokens
# for the "Share to Facebook" flow (the flyer is uploaded so Facebook's scraper can
# read it as the link preview image).
#
# Create a Blob store in the Vercel dashboard (Storage -> Blob); the token is added
# to your deployment automatically. For local dev, run `vercel env pull` to fetch it.
# Sharing only works on a public HTTPS deployment — Facebook cannot scrape localhost.
BLOB_READ_WRITE_TOKEN=
