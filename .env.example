# Origin(s) allowed to embed this app in an <iframe> (CSP frame-ancestors).
# Set this in your Vercel project: Settings -> Environment Variables.
#
# Single origin:
#   ALLOWED_FRAME_ANCESTOR=https://official.example
#
# Multiple origins (space-separated, e.g. prod + staging):
#   ALLOWED_FRAME_ANCESTOR=https://official.example https://staging.official.example
#
# Leave unset to deny ALL framing (deny-by-default). The app still loads directly.
ALLOWED_FRAME_ANCESTOR=
